<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Shared hosting may point to the project root instead of public/.
    # Always serve the app through public/ without exposing project files.
    RewriteRule ^$ public/index.php [L]
    RewriteRule ^public/ - [L]
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
